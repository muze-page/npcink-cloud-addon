msgid "Cloud media derivative job type is invalid."
msgstr "Cloud 媒体衍生任务类型无效。"

#: includes/class-cloud-media-derivative-transport.php:360
msgid "Media derivative jobs must not request original file replacement."
msgstr "媒体衍生任务不得请求替换原始文件。"

#: includes/class-cloud-media-derivative-transport.php:389
msgid "Watermark artifact transport requires a watermark plan in the ability response."
msgstr "水印 artifact 传输要求 ability response 中包含水印计划。"

#: includes/class-cloud-media-derivative-transport.php:396
msgid "Text watermark plans must not include a watermark upload or artifact id."
msgstr "文本水印计划不得包含水印上传或 artifact id。"

#: includes/class-cloud-media-derivative-transport.php:410
msgid "Watermark plans require a watermark upload or artifact id before Cloud dispatch."
msgstr "派发到 Cloud 前，水印计划需要水印上传或 artifact id。"

