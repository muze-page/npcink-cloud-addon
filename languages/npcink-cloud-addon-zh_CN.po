msgid "Media derivative final write owner must remain the local WordPress host."
msgstr "媒体衍生的最终写入所有者必须保留为本地 WordPress 主机。"

#: includes/class-cloud-media-derivative-transport.php:760
msgid "Media derivative request must not include WordPress writes."
msgstr "媒体衍生请求不得包含 WordPress 写入。"

#: includes/class-cloud-media-derivative-transport.php:767
msgid "Media derivative ability payload must not include credentials or signed headers."
msgstr "媒体衍生 ability payload 不得包含凭据或签名请求头。"

#: includes/class-cloud-media-derivative-transport.php:776
msgid "Cloud media derivative job type is invalid."
msgstr "Cloud 媒体衍生任务类型无效。"

#: includes/class-cloud-media-derivative-transport.php:783
msgid "Media derivative jobs must not request original file replacement."
msgstr "媒体衍生任务不得请求替换原始文件。"

