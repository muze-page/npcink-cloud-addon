msgid "Cloud derivative artifact download returned no bytes."
msgstr "Cloud 衍生 artifact 下载未返回内容。"

#: includes/class-cloud-media-derivative-transport.php:389
msgid "Cloud derivative artifact mime type does not match the descriptor."
msgstr "Cloud 衍生 artifact 的 MIME 类型与描述不匹配。"

#: includes/class-cloud-media-derivative-transport.php:398
#: includes/class-cloud-media-derivative-transport.php:1209
msgid "Media derivative artifact mime type must be a supported image type."
msgstr "媒体衍生 artifact 的 MIME 类型必须是受支持的图片类型。"

