#. Description of the plugin
#: npcink-cloud-addon.php
msgid "Cloud connector for Npcink hosted runtime access, signing, health checks, and entitlement summaries."
msgstr "用于 Npcink 托管运行时访问、签名、健康检查和权益摘要的 Cloud 连接器。"

#. Author of the plugin
#: npcink-cloud-addon.php
msgid "Npcink"
msgstr "Npcink"

