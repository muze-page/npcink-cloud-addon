#: includes/class-cloud-media-derivative-transport.php:1072
msgid "Media derivative upload file exceeds the Cloud size limit."
msgstr "媒体衍生上传文件超过 Cloud 大小限制。"

#: includes/class-cloud-media-derivative-transport.php:1065
msgid "Media derivative upload file is empty."
msgstr "媒体衍生上传文件为空。"

#: includes/class-cloud-media-derivative-transport.php:1155
msgid "Media derivative runtime artifacts require an artifact id."
msgstr "媒体衍生运行时 artifact 需要 artifact id。"

#: includes/class-cloud-media-derivative-transport.php:1175
msgid "Media derivative artifact expiry is required."
msgstr "媒体衍生 artifact 需要过期时间。"

#: includes/class-cloud-media-derivative-transport.php:1182
msgid "Expired Cloud artifacts cannot be adopted."
msgstr "已过期的 Cloud artifact 不能被采用。"

#: includes/class-cloud-media-derivative-transport.php:1191
msgid "Derivative Cloud artifacts require an artifact id before local proposal adoption."
msgstr "本地提案采用前，Cloud 衍生 artifact 需要 artifact id。"

#: includes/class-cloud-media-derivative-transport.php:1200
msgid "Media derivative artifact requires an artifact id or download URL."
msgstr "媒体衍生 artifact 需要 artifact id 或下载 URL。"

#: includes/class-cloud-media-derivative-transport.php:1313
msgid "Derivative artifact id does not match the Cloud result."
msgstr "衍生 artifact id 与 Cloud 结果不匹配。"

#: includes/class-cloud-media-derivative-transport.php:1323
msgid "Derivative artifact run_id does not match the Cloud result."
msgstr "衍生 artifact run_id 与 Cloud 结果不匹配。"

#: includes/class-cloud-media-derivative-transport.php:1333
msgid "Derivative artifact checksum does not match the Cloud result."
msgstr "衍生 artifact 校验和与 Cloud 结果不匹配。"

