msgid "Cloud API Key cannot be empty."
msgstr "Cloud API 密钥不能为空。"

#: includes/class-cloud-addon-settings.php:455
msgid "Cloud API Key could not be decoded."
msgstr "无法解码 Cloud API 密钥。"

#: includes/class-cloud-addon-settings.php:463
msgid "Cloud API Key format is invalid. Use a key issued by Npcink Cloud."
msgstr "Cloud API 密钥格式无效。请使用 Npcink Cloud 签发的密钥。"

#: includes/class-cloud-entitlement-summary.php:32
#: includes/class-cloud-entitlement-summary.php:75
msgid "Configure Cloud settings before reading entitlement."
msgstr "读取权益信息前请先配置 Cloud 设置。"

#: includes/class-cloud-entitlement-summary.php:38
#: includes/class-cloud-entitlement-summary.php:81
msgid "Entitlement is unavailable until Cloud settings verify successfully."
msgstr "Cloud 设置验证成功前，权益信息不可用。"

#: includes/class-cloud-entitlement-summary.php:188
msgid "Entitlement summary synced."
msgstr "权益摘要已同步。"

#: includes/class-cloud-media-derivative-transport.php:48
msgid "Source upload and source artifact id cannot be sent together."
msgstr "不能同时发送源文件上传和源 artifact id。"

#: includes/class-cloud-media-derivative-transport.php:72
#: includes/class-cloud-media-derivative-transport.php:826
msgid "Watermark upload and watermark artifact id cannot be sent together."
msgstr "不能同时发送水印上传和水印 artifact id。"

#: includes/class-cloud-media-derivative-transport.php:379
msgid "Cloud derivative artifact download returned no bytes."
msgstr "Cloud 衍生 artifact 下载未返回内容。"

#: includes/class-cloud-media-derivative-transport.php:389
msgid "Cloud derivative artifact mime type does not match the descriptor."
msgstr "Cloud 衍生 artifact 的 MIME 类型与描述不匹配。"

#: includes/class-cloud-media-derivative-transport.php:398
#: includes/class-cloud-media-derivative-transport.php:1209
msgid "Media derivative artifact mime type must be a supported image type."
msgstr "媒体衍生 artifact 的 MIME 类型必须是受支持的图片类型。"

#: includes/class-cloud-media-derivative-transport.php:407
msgid "Derivative artifact checksum does not match the downloaded bytes."
msgstr "衍生 artifact 校验和与下载内容不匹配。"

#: includes/class-cloud-media-derivative-transport.php:692
msgid "Npcink Cloud credentials must verify before dispatching media derivative jobs."
msgstr "派发媒体衍生任务前，Npcink Cloud 凭据必须先通过验证。"

#: includes/class-cloud-media-derivative-transport.php:739
msgid "Media derivative request contract version is invalid."
msgstr "媒体衍生请求的合同版本无效。"

#: includes/class-cloud-media-derivative-transport.php:746
msgid "Media derivative request must be read-only and proposal-only."
msgstr "媒体衍生请求必须是只读且仅生成提案。"

#: includes/class-cloud-media-derivative-transport.php:753
msgid "Media derivative final write owner must remain the local WordPress host."
msgstr "媒体衍生的最终写入所有者必须保留为本地 WordPress 主机。"

#: includes/class-cloud-media-derivative-transport.php:760
msgid "Media derivative request must not include WordPress writes."
msgstr "媒体衍生请求不得包含 WordPress 写入。"

#: includes/class-cloud-media-derivative-transport.php:767
msgid "Media derivative ability payload must not include credentials or signed headers."
msgstr "媒体衍生 ability payload 不得包含凭据或签名请求头。"

#: includes/class-cloud-media-derivative-transport.php:776
msgid "Cloud media derivative job type is invalid."
msgstr "Cloud 媒体衍生任务类型无效。"

#: includes/class-cloud-media-derivative-transport.php:783
msgid "Media derivative jobs must not request original file replacement."
msgstr "媒体衍生任务不得请求替换原始文件。"

#: includes/class-cloud-media-derivative-transport.php:812
msgid "Watermark artifact transport requires a watermark plan in the ability response."
msgstr "水印 artifact 传输要求 ability response 中包含水印计划。"

#: includes/class-cloud-media-derivative-transport.php:819
msgid "Text watermark plans must not include a watermark upload or artifact id."
msgstr "文本水印计划不得包含水印上传或 artifact id。"

#: includes/class-cloud-media-derivative-transport.php:833
msgid "Watermark plans require a watermark upload or artifact id before Cloud dispatch."
msgstr "派发到 Cloud 前，水印计划需要水印上传或 artifact id。"

#: includes/class-cloud-media-derivative-transport.php:842
msgid "Media derivative request must include a bounded target format from the ability response."
msgstr "媒体衍生请求必须包含 ability response 提供的受限目标格式。"

#: includes/class-cloud-media-derivative-transport.php:851
msgid "Media derivative request must include max_width from the ability response."
msgstr "媒体衍生请求必须包含 ability response 中的 max_width。"

#: includes/class-cloud-media-derivative-transport.php:860
msgid "Media derivative request must include quality from the ability response."
msgstr "媒体衍生请求必须包含 ability response 中的 quality。"

#: includes/class-cloud-media-derivative-transport.php:876
msgid "Media derivative source media type must be a supported image type."
msgstr "媒体衍生源媒体类型必须是受支持的图片类型。"

#: includes/class-cloud-media-derivative-transport.php:892
msgid "Watermark artifact id does not match the ability watermark plan."
msgstr "水印 artifact id 与 ability 水印计划不匹配。"

#: includes/class-cloud-media-derivative-transport.php:1039
msgid "Media derivative upload file is not readable."
msgstr "媒体衍生上传文件不可读。"

