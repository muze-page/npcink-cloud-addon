msgid "Media derivative request must include max_width from the ability response."
msgstr "媒体衍生请求必须包含 ability response 中的 max_width。"

#: includes/class-cloud-media-derivative-transport.php:860
msgid "Media derivative request must include quality from the ability response."
msgstr "媒体衍生请求必须包含 ability response 中的 quality。"

#: includes/class-cloud-media-derivative-transport.php:876
msgid "Media derivative source media type must be a supported image type."
msgstr "媒体衍生源媒体类型必须是受支持的图片类型。"

